{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "session-tracker-gui",
  "version": "0.5.0",
  "identifier": "com.connor.session-tracker-gui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173", 
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "session-tracker-gui",
        "width": 800,
        "height": 600,
        "minWidth": 420,
        "minHeight": 350,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDExMjVEMzdBN0E2REVERjEKUldUeDdXMTZldE1sRVVOc0p5ek9LQnZqenBaZUl5NzhrU05FZHBnajdJeEhEUGJ0MVdoUFo4WDcK",
      "endpoints": [
        "https://github.com/Cjeera/session-tracker-gui/releases/latest/download/latest.json"
      ]
    }
  }
}
